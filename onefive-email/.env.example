# Resend (required for real delivery when the backend calls this service)
# Inutile en dev tant que EMAIL_DEV_SINK=true : le sink ne contacte jamais Resend.
RESEND_API_KEY=

# Dev : détourne tous les emails vers Mailpit au lieu de Resend (aucun envoi réel).
# Le HTML rendu est identique à celui de la prod — c'est le seul moyen de voir un
# template avec les vraies données envoyées par onefive-back.
# Démarrer Mailpit : docker compose -f ../onefive-back/docker-compose.yml up -d mailpit
# Boîte de réception : http://localhost:8025
# Ne jamais activer en production (le service refusera de démarrer).
EMAIL_DEV_SINK=true
MAILPIT_HOST=127.0.0.1
MAILPIT_PORT=2525

# Shared secret: must match onefive-back ONEFIVE_MICROSERVICE_EMAIL_API_KEY (x-api-key header)
API_KEY=azerty

# Frontend URL (used in email templates for action links)
FRONTEND_URL=http://localhost:3002

# Database (Prisma) — used for email logs / webhook events
DATABASE_URL=postgresql://username:password@localhost:5432/onefive?schema=public