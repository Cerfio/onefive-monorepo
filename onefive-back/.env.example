# ========================================
# OneFive Backend - Environment Variables
# Copy this file to .env and fill in values
# ========================================

# App
PORT=50050
NODE_ENV=development
FRONTEND_URL=http://localhost:3002

# Database - PostgreSQL (with PostGIS)
DATABASE_URL=postgresql://username:password@localhost:5432/onefive?schema=public

# Hashing & Security
# SESSION_SECRET must be set — no fallback in production (openssl rand -hex 32)
SESSION_SECRET=your_session_secret_key_here
KEY_AUTHENTICATION=your_authentication_key_here

# OAuth - LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:50050/auth/linkedin/callback
LINKEDIN_CALLBACK_URL_SYNC=http://localhost:50050/auth/linkedin/callback/sync

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth Redirect URIs (frontend)
AUTH_REDIRECT_URI=http://localhost:3002/auth/oauth2/callback
AUTH_REDIRECT_URI_ONBOARDING=http://localhost:3002/auth/oauth2/callback/onboarding

# SMS - Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Storage - Cloudflare R2 (or LocalStack for dev)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=onefive-storage
R2_PUBLIC_URL=https://your-storage-domain.com
STORAGE_URL=https://your-storage-domain.com
S3_BUCKET_NAME=onefive-storage
PUBLIC_BUCKET_NAME=onefive-public

# Email Microservice (onefive-email Next app — /api/send, default port 3009)
# For real sends locally: run `pnpm dev:app-with-email` or `pnpm dev:platform-with-email` from the repo root,
# copy onefive-email/.env.example → .env there (RESEND_API_KEY, API_KEY), and set ONEFIVE_MICROSERVICE_EMAIL_API_KEY
# to the same value as API_KEY in onefive-email.
# To skip HTTP calls and log only: MOCK_EMAIL_SERVICE=true or DISABLE_EMAIL_SENDING=true
ONEFIVE_MICROSERVICE_EMAIL_URL=http://localhost:3009
ONEFIVE_MICROSERVICE_EMAIL_API_KEY=your_email_api_key
# MOCK_EMAIL_SERVICE=true
# DISABLE_EMAIL_SENDING=true

# LinkedIn Scraping - Apify
APIFY_API_TOKEN=your_apify_api_token
APIFY_LINKEDIN_ACTOR_ID=harvestapi~linkedin-profile-scraper

# Discord Webhooks (optional — leave empty to disable)
DISCORD_WEBHOOK_OPS_ALERTS=
DISCORD_WEBHOOK_OPS_INSCRIPTIONS=
DISCORD_WEBHOOK_OPS_FEEDBACK=

# Monitoring & Logging (optional)
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000

# Redis (for sessions cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# PostHog Analytics (optional — leave empty to disable)
POSTHOG_API_KEY=
