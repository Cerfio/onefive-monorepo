{
  "name": "onefive-back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts",
    "schema": "./prisma/schema/"
  },
  "scripts": {
    "dev": "nest start --watch",
    "db:reset": "prisma migrate reset --force --schema=./prisma/schema/",
    "db:validate": "prisma validate --schema=./prisma/schema/",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema/",
    "db:migrate:prod": "prisma migrate deploy --schema=./prisma/schema/",
    "db:push": "prisma db push --schema=./prisma/schema/",
    "db:generate": "prisma generate --schema=./prisma/schema/",
    "db:studio": "prisma studio --schema=./prisma/schema/",
    "db:seed": "npx tsx prisma/seed.ts",
    "localstack:setup": "bash scripts/setup-localstack.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest --config jest-unit.config.js",
    "test:unit:clean": "jest --testPathIgnorePatterns='e2e|performance|integration' --no-coverage --forceExit",
    "test:e2e": "jest --testPathPattern=\\.e2e-spec\\.ts$ --runInBand --forceExit",
    "test:e2e:flows": "jest --testPathPattern=flows.*e2e-spec --runInBand --forceExit",
    "test:e2e:flow": "jest --runInBand --forceExit",
    "test:e2e:standalone": "jest --testPathPattern=e2e-spec\\.ts$ --testPathIgnorePatterns='flows|debug|validation' --runInBand --forceExit",
    "test:e2e:security": "jest --testPathPattern='(auth-cookies|waitlist|password-reset-brute|signed-url|idor|xss|file-upload)' --runInBand --forceExit",
    "test:e2e:validation": "jest --testPathPattern=validation.*e2e --runInBand --forceExit",
    "test:auth": "jest --testPathPattern=auth.*\\.spec\\.ts$",
    "test:handlers": "jest --testPathPattern=.*handler.*\\.spec\\.ts$",
    "test:controllers": "jest --testPathPattern=.*controller.*\\.spec\\.ts$",
    "test:services": "jest --testPathPattern=.*service.*\\.spec\\.ts$",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:cov:unit": "jest --coverage --testPathPattern=\\.spec\\.ts$ --testPathIgnorePatterns=e2e-spec",
    "test:cov:e2e": "jest --coverage --testPathPattern=\\.e2e-spec\\.ts$",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e:legacy": "jest --config ./test/jest-e2e.json --runInBand",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:manifest": "npm run test:unit && echo '\n📋 Voir test/TEST_MANIFEST.md pour la checklist complète'",
    "test:apify": "ts-node scripts/test-apify-scraper.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/lib-storage": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.893.0",
    "@faker-js/faker": "^9.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.2.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.13",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.16.3",
    "@sentry/nestjs": "^10.49.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "fastify": "^5.6.0",
    "helmet": "^8.1.0",
    "logstash-winston-3": "^2.1.3",
    "posthog-node": "^5.26.0",
    "react-image-crop": "^11.0.10",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.4",
    "socket.io": "^4.8.3",
    "twilio": "^5.10.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.23",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.17",
    "@types/pg": "^8.16.0",
    "@types/react-image-crop": "^9.0.2",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "pg": "^8.18.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
