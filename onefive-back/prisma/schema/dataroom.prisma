model Dataroom {
  id                     String                   @id @default(uuid())
  startupId              String                   @unique
  pitchVideo             String?
  createdBy              String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  startup                Startup                  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  accessLogs             AccessLog[]
  logs                   ActivityLog[]
  captables              Captable[]
  categories             Category[]
  comments               DataroomFileComment[]
  files                  DataroomFile[]
  groups                 DataroomGroup[]
  invitations            DataroomInvitation[]
  notifications          DataroomNotification[]
  directAccess           DirectAccess[]
  existingUserInvitation ExistingUserInvitation[]
  fundraising            Fundraising[]
  kpis                   KPI[]
  members                Member[]
  newUserInvitation      NewUserInvitation[]
  questionAndAnswers     QuestionAndAnswer[]
  roadmap                Roadmap[]
  trackingEvents         TrackingEvent[]
}

model Captable {
  id         String    @id @default(uuid())
  profileId  String
  stock      Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  dataroomId String?
  dataroom   Dataroom? @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model QuestionAndAnswer {
  id         String    @id @default(uuid())
  question   String
  answer     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  dataroomId String?
  dataroom   Dataroom? @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model KPI {
  id          String         @id @default(uuid())
  name        String
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  recurrence  KPIRecurrence
  dataroomId  String?
  createdBy   String
  groupId     String?
  dataroom    Dataroom?      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  group       DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  history     KPIHistory[]
}

model KPIHistory {
  id        String   @id @default(uuid())
  kpiId     String
  value     Float
  timestamp DateTime @default(now())
  notes     String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kpi       KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
}

model Roadmap {
  id          String        @id @default(uuid())
  dataroomId  String
  title       String
  description String
  targetValue Float
  startDate   DateTime
  endDate     DateTime
  status      RoadmapStatus @default(PLANNED)
  notes       String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  dataroom    Dataroom      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
}

model DataroomGroup {
  id                  String               @id @default(uuid())
  dataroomId          String
  name                String
  type                GroupType
  createdBy           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  hasAllAccess        Boolean
  canUpload           Boolean
  canShare            Boolean
  canManageUsers      Boolean
  canManageGroups     Boolean
  dataroom            Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  invitations         DataroomInvitation[]
  kpis                KPI[]
  members             Member[]
  permissionsCategory PermissionCategory[]
  permissionsFile     PermissionFile[]

  @@index([dataroomId])
}

model Member {
  id         String        @id @default(uuid())
  groupId    String
  profileId  String
  dataroomId String
  createdAt  DateTime      @default(now())
  dataroom   Dataroom      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  group      DataroomGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
  @@index([groupId])
  @@index([dataroomId, profileId])
}

model PermissionCategory {
  id          String         @id @default(uuid())
  canView     Boolean
  canDownload Boolean
  canComment  Boolean
  givenBy     String
  createdAt   DateTime       @default(now())
  groupId     String?
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group       DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([categoryId, groupId])
}

model PermissionFile {
  id             String         @id @default(uuid())
  canView        Boolean
  canDownload    Boolean
  canComment     Boolean
  givenBy        String
  createdAt      DateTime       @default(now())
  groupId        String?
  fileId         String?
  directAccessId String?
  DirectAccess   DirectAccess?  @relation(fields: [directAccessId], references: [id], onDelete: Cascade)
  file           DataroomFile?  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  group          DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([fileId, groupId])
}

model Category {
  id          String               @id @default(uuid())
  name        String
  dataroomId  String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   String
  dataroom    Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  files       DataroomFile[]
  permissions PermissionCategory[]

  @@unique([name, dataroomId])
}

model DataroomFile {
  id             String           @id @default(uuid())
  dataroomId     String
  name           String
  size           Int
  mimetype       String
  storageId      String           @unique
  categoryId     String
  uploadedBy     String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  fundraisingId  String?
  accessLogs     AccessLog[]
  category       Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dataroom       Dataroom              @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  fundraising    Fundraising?          @relation(fields: [fundraisingId], references: [id], onDelete: Cascade)
  comments       DataroomFileComment[]
  directAccess   DirectAccess[]
  PermissionFile PermissionFile[]
  trackingEvents TrackingEvent[]

  @@index([dataroomId])
  @@index([categoryId])
}

model AccessLog {
  id         String       @id @default(uuid())
  dataroomId String
  fileId     String
  profileId  String
  action     AccessAction
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime     @default(now())
  dataroom   Dataroom     @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file       DataroomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([fileId])
  @@index([profileId])
  @@index([dataroomId, action])
}

model DirectAccess {
  id            String           @id @default(uuid())
  dataroomId    String
  profileId     String
  fileId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String
  endAccessTime DateTime?
  dataroom      Dataroom         @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file          DataroomFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  permissions   PermissionFile[]

  @@unique([profileId, dataroomId, fileId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  dataroomId String
  profileId  String
  action     String
  metadata   Json?
  timestamp  DateTime @default(now())
  dataroom   Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
}

model DataroomNotification {
  id         String   @id @default(uuid())
  dataroomId String
  profileId  String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  dataroom   Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
  @@index([profileId, read])
}

model Fundraising {
  id                 String                     @id @default(uuid())
  dataroomId         String
  roundType          FundraisingRound
  preMoneyValuation  Float
  amountRaised       Float
  postMoneyValuation Float
  pricePerShare      Float
  totalShares        Float
  percentageDiluted  Float
  date               DateTime
  notes              String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  documents          DataroomFile[]
  dataroom           Dataroom                   @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  capTableEntries    FundraisingCapTableEntry[]
}

model FundraisingCapTableEntry {
  id              String      @id @default(uuid())
  fundraisingId   String
  profileId       String?
  name            String
  role            String
  shares          Float
  percentage      Float
  valueInCurrency Float
  createdAt       DateTime    @default(now())
  fundraising     Fundraising @relation(fields: [fundraisingId], references: [id], onDelete: Cascade)
}

model DataroomInvitation {
  id                       String                  @id @default(uuid())
  dataroomId               String
  status                   InvitationStatus
  groupId                  String
  createdBy                String
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  existingUserInvitationId String?
  newUserInvitationId      String?
  dataroom                 Dataroom                @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  existingUserInvitation   ExistingUserInvitation? @relation(fields: [existingUserInvitationId], references: [id], onDelete: Cascade)
  group                    DataroomGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  newUserInvitation        NewUserInvitation?      @relation(fields: [newUserInvitationId], references: [id], onDelete: Cascade)
}

model ExistingUserInvitation {
  id                 String               @id @default(uuid())
  profileId          String
  dataroomId         String
  DataroomInvitation DataroomInvitation[]
  dataroom           Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model NewUserInvitation {
  id                 String               @id @default(uuid())
  email              String
  firstname          String
  lastname           String
  dataroomName       String
  dataroomId         String
  DataroomInvitation DataroomInvitation[]
  dataroom           Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model TrackingEvent {
  id              String       @id @default(uuid())
  eventType       String
  dataroomId      String
  fileId          String
  profileId       String
  sessionId       String
  timestamp       DateTime     @default(now())
  sessionDuration Int?
  additionalData  Json?
  ipAddress       String?
  userAgent       String?
  dataroom        Dataroom     @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file            DataroomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([fileId])
  @@index([profileId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([eventType])
}

enum KPIRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RoadmapStatus {
  PLANNED
  INPROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

enum GroupType {
  DEFAULT
  CUSTOM
}

enum AccessAction {
  VIEW
  DOWNLOAD
  COMMENT
  SHARE
  DELETE
  EDIT
}

enum FundraisingRound {
  PRESEED
  SEED
  SERIESA
  SERIESB
  SERIESC
  SERIESD
  BRIDGE
  VENTUREDEBT
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum InvitationType {
  GROUP
  DIRECTACCESS
}

model DataroomFileComment {
  id         String                @id @default(uuid())
  dataroomId String
  fileId     String
  profileId  String
  content    String                @db.VarChar(3000)
  pageNumber Int?
  parentId   String?
  isDeleted  Boolean               @default(false)
  deletedAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  dataroom   Dataroom              @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file       DataroomFile          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parent     DataroomFileComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    DataroomFileComment[] @relation("CommentReplies")

  @@index([fileId, createdAt])
  @@index([profileId])
  @@index([parentId])
}
