// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: Models are defined in one or more files under prisma/schema/*.prisma


model AdminUser {
  id          String              @id @default(uuid())
  email       String              @unique
  password    String
  firstName   String?
  lastName    String?
  isActive    Boolean             @default(true)
  isSuperAdmin Boolean            @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sessions    AdminSession[]
  roles       AdminUserRole[]
  auditLogs   AdminAuditLog[]
  sentInvitations AdminInvitation[] @relation("AdminInvitationInvitedBy")
  acceptedInvitations AdminInvitation[] @relation("AdminInvitationAcceptedBy")
}

model AdminSession {
  id          String    @id @default(uuid())
  token       String    @unique
  adminUserId String
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  lastUsage   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userAgent   String    @default("")
  ipAddress   String    @default("")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model AdminRole {
  id          String                @id @default(uuid())
  key         String                @unique
  name        String
  description String?
  isSystem    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  users       AdminUserRole[]
  permissions AdminRolePermission[]
  invitations AdminInvitation[]
}

model AdminPermission {
  id          String                @id @default(uuid())
  key         String                @unique
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  roles       AdminRolePermission[]
}

model AdminUserRole {
  adminUserId String
  roleId      String
  assignedAt  DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@index([roleId])
}

model AdminRolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime        @default(now())
  role         AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AdminInvitation {
  id          String                @id @default(uuid())
  email       String
  roleId      String
  token       String                @unique
  status      AdminInvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  acceptedById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  role        AdminRole             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy   AdminUser             @relation("AdminInvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy  AdminUser?            @relation("AdminInvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, expiresAt])
}

model AdminAuditLog {
  id           String    @id @default(uuid())
  adminUserId  String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum AdminInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}


// Badge system for waitlist achievements
model Badge {
  id          String    @id @default(uuid())
  type        BadgeType @unique
  name        String
  description String
  iconUrl     String?
  createdAt   DateTime  @default(now())
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  profileId String
  badgeId   String
  awardedAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([profileId, badgeId])
  @@index([profileId])
}

enum BadgeType {
  EARLY_ADOPTER
  FOUNDING_MEMBER
}


model Dataroom {
  id                     String                   @id @default(uuid())
  startupId              String                   @unique
  pitchVideo             String?
  createdBy              String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  startup                Startup                  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  accessLogs             AccessLog[]
  logs                   ActivityLog[]
  captables              Captable[]
  categories             Category[]
  comments               DataroomFileComment[]
  files                  DataroomFile[]
  groups                 DataroomGroup[]
  invitations            DataroomInvitation[]
  notifications          DataroomNotification[]
  directAccess           DirectAccess[]
  existingUserInvitation ExistingUserInvitation[]
  fundraising            Fundraising[]
  kpis                   KPI[]
  members                Member[]
  newUserInvitation      NewUserInvitation[]
  questionAndAnswers     QuestionAndAnswer[]
  roadmap                Roadmap[]
  trackingEvents         TrackingEvent[]
}

model Captable {
  id         String    @id @default(uuid())
  profileId  String
  stock      Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  dataroomId String?
  dataroom   Dataroom? @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model QuestionAndAnswer {
  id         String    @id @default(uuid())
  question   String
  answer     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  dataroomId String?
  dataroom   Dataroom? @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model KPI {
  id          String         @id @default(uuid())
  name        String
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  recurrence  KPIRecurrence
  dataroomId  String?
  createdBy   String
  groupId     String?
  dataroom    Dataroom?      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  group       DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  history     KPIHistory[]
}

model KPIHistory {
  id        String   @id @default(uuid())
  kpiId     String
  value     Float
  timestamp DateTime @default(now())
  notes     String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kpi       KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
}

model Roadmap {
  id          String        @id @default(uuid())
  dataroomId  String
  title       String
  description String
  targetValue Float
  startDate   DateTime
  endDate     DateTime
  status      RoadmapStatus @default(PLANNED)
  notes       String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  dataroom    Dataroom      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
}

model DataroomGroup {
  id                  String               @id @default(uuid())
  dataroomId          String
  name                String
  type                GroupType
  createdBy           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  hasAllAccess        Boolean
  canUpload           Boolean
  canShare            Boolean
  canManageUsers      Boolean
  canManageGroups     Boolean
  dataroom            Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  invitations         DataroomInvitation[]
  kpis                KPI[]
  members             Member[]
  permissionsCategory PermissionCategory[]
  permissionsFile     PermissionFile[]

  @@index([dataroomId])
}

model Member {
  id         String        @id @default(uuid())
  groupId    String
  profileId  String
  dataroomId String
  createdAt  DateTime      @default(now())
  dataroom   Dataroom      @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  group      DataroomGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
  @@index([groupId])
  @@index([dataroomId, profileId])
}

model PermissionCategory {
  id          String         @id @default(uuid())
  canView     Boolean
  canDownload Boolean
  canComment  Boolean
  givenBy     String
  createdAt   DateTime       @default(now())
  groupId     String?
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group       DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([categoryId, groupId])
}

model PermissionFile {
  id             String         @id @default(uuid())
  canView        Boolean
  canDownload    Boolean
  canComment     Boolean
  givenBy        String
  createdAt      DateTime       @default(now())
  groupId        String?
  fileId         String?
  directAccessId String?
  DirectAccess   DirectAccess?  @relation(fields: [directAccessId], references: [id], onDelete: Cascade)
  file           DataroomFile?  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  group          DataroomGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([fileId, groupId])
}

model Category {
  id          String               @id @default(uuid())
  name        String
  dataroomId  String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   String
  dataroom    Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  files       DataroomFile[]
  permissions PermissionCategory[]

  @@unique([name, dataroomId])
}

model DataroomFile {
  id             String           @id @default(uuid())
  dataroomId     String
  name           String
  size           Int
  mimetype       String
  storageId      String           @unique
  categoryId     String
  uploadedBy     String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  fundraisingId  String?
  accessLogs     AccessLog[]
  category       Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dataroom       Dataroom              @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  fundraising    Fundraising?          @relation(fields: [fundraisingId], references: [id], onDelete: Cascade)
  comments       DataroomFileComment[]
  directAccess   DirectAccess[]
  PermissionFile PermissionFile[]
  trackingEvents TrackingEvent[]

  @@index([dataroomId])
  @@index([categoryId])
}

model AccessLog {
  id         String       @id @default(uuid())
  dataroomId String
  fileId     String
  profileId  String
  action     AccessAction
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime     @default(now())
  dataroom   Dataroom     @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file       DataroomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([fileId])
  @@index([profileId])
  @@index([dataroomId, action])
}

model DirectAccess {
  id            String           @id @default(uuid())
  dataroomId    String
  profileId     String
  fileId        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String
  endAccessTime DateTime?
  dataroom      Dataroom         @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file          DataroomFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  permissions   PermissionFile[]

  @@unique([profileId, dataroomId, fileId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  dataroomId String
  profileId  String
  action     String
  metadata   Json?
  timestamp  DateTime @default(now())
  dataroom   Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
}

model DataroomNotification {
  id         String   @id @default(uuid())
  dataroomId String
  profileId  String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  dataroom   Dataroom @relation(fields: [dataroomId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([profileId])
  @@index([profileId, read])
}

model Fundraising {
  id                 String                     @id @default(uuid())
  dataroomId         String
  roundType          FundraisingRound
  preMoneyValuation  Float
  amountRaised       Float
  postMoneyValuation Float
  pricePerShare      Float
  totalShares        Float
  percentageDiluted  Float
  date               DateTime
  notes              String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  documents          DataroomFile[]
  dataroom           Dataroom                   @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  capTableEntries    FundraisingCapTableEntry[]
}

model FundraisingCapTableEntry {
  id              String      @id @default(uuid())
  fundraisingId   String
  profileId       String?
  name            String
  role            String
  shares          Float
  percentage      Float
  valueInCurrency Float
  createdAt       DateTime    @default(now())
  fundraising     Fundraising @relation(fields: [fundraisingId], references: [id], onDelete: Cascade)
}

model DataroomInvitation {
  id                       String                  @id @default(uuid())
  dataroomId               String
  status                   InvitationStatus
  groupId                  String
  createdBy                String
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  existingUserInvitationId String?
  newUserInvitationId      String?
  dataroom                 Dataroom                @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  existingUserInvitation   ExistingUserInvitation? @relation(fields: [existingUserInvitationId], references: [id], onDelete: Cascade)
  group                    DataroomGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  newUserInvitation        NewUserInvitation?      @relation(fields: [newUserInvitationId], references: [id], onDelete: Cascade)
}

model ExistingUserInvitation {
  id                 String               @id @default(uuid())
  profileId          String
  dataroomId         String
  DataroomInvitation DataroomInvitation[]
  dataroom           Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model NewUserInvitation {
  id                 String               @id @default(uuid())
  email              String
  firstname          String
  lastname           String
  dataroomName       String
  dataroomId         String
  DataroomInvitation DataroomInvitation[]
  dataroom           Dataroom             @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
}

model TrackingEvent {
  id              String       @id @default(uuid())
  eventType       String
  dataroomId      String
  fileId          String
  profileId       String
  sessionId       String
  timestamp       DateTime     @default(now())
  sessionDuration Int?
  additionalData  Json?
  ipAddress       String?
  userAgent       String?
  dataroom        Dataroom     @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file            DataroomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([dataroomId])
  @@index([fileId])
  @@index([profileId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([eventType])
}

enum KPIRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RoadmapStatus {
  PLANNED
  INPROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

enum GroupType {
  DEFAULT
  CUSTOM
}

enum AccessAction {
  VIEW
  DOWNLOAD
  COMMENT
  SHARE
  DELETE
  EDIT
}

enum FundraisingRound {
  PRESEED
  SEED
  SERIESA
  SERIESB
  SERIESC
  SERIESD
  BRIDGE
  VENTUREDEBT
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum InvitationType {
  GROUP
  DIRECTACCESS
}

model DataroomFileComment {
  id         String                @id @default(uuid())
  dataroomId String
  fileId     String
  profileId  String
  content    String                @db.VarChar(3000)
  pageNumber Int?
  parentId   String?
  isDeleted  Boolean               @default(false)
  deletedAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  dataroom   Dataroom              @relation(fields: [dataroomId], references: [id], onDelete: Cascade)
  file       DataroomFile          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parent     DataroomFileComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    DataroomFileComment[] @relation("CommentReplies")

  @@index([fileId, createdAt])
  @@index([profileId])
  @@index([parentId])
}


model Discussion {
  id                 String               @id @default(uuid())
  profileId          String
  question           String
  questionUnaccented String
  content            String?
  context            String?
  options            String[]
  tags               String[]
  type               DiscussionType
  isHidden           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  author             Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  answers            DiscussionAnswer[]
  reactions          DiscussionReaction[]
  upvotes            DiscussionUpvote[]
  views              DiscussionView[]
  pollVotes          DiscussionPollVote[]

  @@index([profileId])
  @@index([createdAt])
}

model DiscussionView {
  id           String     @id @default(uuid())
  discussionId String
  profileId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  viewer       Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([profileId])
}

model DiscussionUpvote {
  id           String     @id @default(uuid())
  profileId    String
  discussionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([discussionId, profileId])
}

model DiscussionReaction {
  id           String       @id @default(uuid())
  reaction     ReactionType
  profileId    String
  discussionId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  discussion   Discussion   @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([discussionId, profileId, reaction])
}

model DiscussionAnswer {
  id           String                     @id @default(uuid())
  profileId    String
  discussionId String
  content      String
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  discussion   Discussion                 @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author       Profile                    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reactions    DiscussionAnswerReaction[]
  replies      DiscussionAnswerReply[]
  upvotes      DiscussionAnswerUpvote[]

  @@index([discussionId])
  @@index([profileId])
}

model DiscussionAnswerReaction {
  id        String           @id @default(uuid())
  reaction  ReactionType
  profileId String
  answerId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  answer    DiscussionAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  profile   Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([answerId, profileId, reaction])
}

model DiscussionAnswerUpvote {
  id        String           @id @default(uuid())
  profileId String
  answerId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  answer    DiscussionAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  profile   Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([answerId, profileId])
}

model DiscussionAnswerReplyReaction {
  id        String                @id @default(uuid())
  reaction  ReactionType
  profileId String
  replyId   String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  profile   Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reply     DiscussionAnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([replyId, profileId, reaction])
}

model DiscussionAnswerReply {
  id        String                          @id @default(uuid())
  profileId String
  answerId  String
  content   String
  createdAt DateTime                        @default(now())
  updatedAt DateTime                        @updatedAt
  answer    DiscussionAnswer                @relation(fields: [answerId], references: [id], onDelete: Cascade)
  author    Profile                         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reactions DiscussionAnswerReplyReaction[]
  upvotes   DiscussionAnswerReplyUpvote[]

  @@index([answerId])
  @@index([profileId])
}

model DiscussionAnswerReplyUpvote {
  id        String                @id @default(uuid())
  profileId String
  replyId   String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  reply     DiscussionAnswerReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  profile   Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([replyId, profileId])
}

model DiscussionPollVote {
  id           String     @id @default(uuid())
  discussionId String
  profileId    String
  option       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([discussionId, profileId, option])
}

enum DiscussionType {
  DISCUSSION
  POLL
  POLL_MULTIPLE
}


model File {
  id                 String              @id @default(cuid())
  size               Int
  mimeType           String
  bucket             String
  url                String?             @db.VarChar(500)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  profileAvatar      Profile[]           @relation("ProfileAvatar")
  profileCover       Profile[]           @relation("ProfileCover")
  messageAttachments MessageAttachment[]
  feedbackScreenshots Feedback[]         @relation("FeedbackScreenshot")
}


model LinkedInCompanySync {
  id                  String   @id @default(uuid())
  startupId           String   @unique
  linkedinCompanyId   String?  // ID LinkedIn de la company (ex: "102583749")
  linkedinUrl         String?
  rawData             Json     // Données brutes de l'API Apify
  lastSyncedAt        DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  startup             Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([lastSyncedAt])
}


model LinkedInSync {
  id                  String   @id @default(uuid())
  profileId           String   @unique
  linkedinPublicId    String?
  linkedinUrl         String?
  rawData             Json     // Données brutes de l'API Apify
  lastSyncedAt        DateTime @default(now())
  syncCount           Int      @default(0) // Nombre de syncs dans la période courante
  syncPeriodStart     DateTime @default(now()) // Début de la période de comptage (trimestre)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([lastSyncedAt])
}



// Messaging Schema - Conversations and Messages

model Conversation {
  id           String               @id @default(uuid())
  type         ConversationType     @default(DIRECT)
  name         String?              // For group conversations
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  messages     Message[]
  participants ConversationMember[]
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  profileId      String
  role           MemberRole   @default(MEMBER)
  isAdmin        Boolean      @default(false)
  isMuted        Boolean      @default(false)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([conversationId, profileId])
  @@index([profileId])
  @@index([conversationId])
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  type           MessageType      @default(TEXT)
  status         MessageStatus    @default(SENT)
  replyToId      String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         Profile          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        Message?         @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]        @relation("MessageReply")
  attachments    MessageAttachment[]
  reactions      MessageReaction[]
  readBy         MessageRead[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageAttachment {
  id        String             @id @default(uuid())
  messageId String
  fileId    String
  type      AttachmentType     @default(FILE)
  createdAt DateTime           @default(now())
  message   Message            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file      File               @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  profileId String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  profile   Profile  @relation("MessageReactions", fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([messageId, profileId, emoji])
  @@index([messageId])
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  profileId String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  profile   Profile  @relation("MessageReads", fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([messageId, profileId])
  @@index([messageId])
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MemberRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  VIDEO
  SYSTEM
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AttachmentType {
  IMAGE
  FILE
  AUDIO
  VIDEO
}


// ─── Flux RSS ──────────────────────────────────────────────────────────────

model NewsletterFeedSource {
  id        String               @id @default(uuid())
  slug      String               @unique
  name      String
  feedUrl   String
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  items     NewsletterFeedItem[]

  @@index([isActive])
}

model NewsletterFeedItem {
  id          String               @id @default(uuid())
  sourceId    String
  externalId  String?
  link        String
  title       String
  summary     String?              @db.Text
  publishedAt DateTime?
  fetchedAt   DateTime             @default(now())
  rawPayload  Json?

  source NewsletterFeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, link])
  @@index([sourceId, publishedAt])
  @@index([publishedAt])
}

// ─── Abonnés ───────────────────────────────────────────────────────────────

enum NewsletterFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
}

model NewsletterSubscriber {
  id               String               @id @default(uuid())
  email            String               @unique
  /// Jeton aléatoire (hex 32 octets) inclus dans les liens d'email.
  /// Permet accès à préférences + désinscription sans compte.
  preferenceToken  String               @unique
  isSubscribed     Boolean              @default(true)
  frequency        NewsletterFrequency  @default(WEEKLY)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  unsubscribedAt   DateTime?

  @@index([isSubscribed])
  @@index([preferenceToken])
}

// ─── Deals extraits ────────────────────────────────────────────────────────

enum NewsletterDealType {
  FUNDRAISING
  MA
  LBO
  OTHER
}

enum NewsletterDealStatus {
  DRAFT
  VALIDATED
  SENT
}

model NewsletterDeal {
  id             String               @id @default(uuid())
  /// Société concernée par l'opération.
  company        String
  dealType       NewsletterDealType   @default(OTHER)
  /// Montant en unité d'origine (ex : "45" pour 45 M€).
  amount         Float?
  currency       String?              @db.VarChar(10)
  /// Tour de financement (Seed, Série A…). Null pour M&A / LBO.
  round          String?
  /// Investisseurs ou acquéreur (liste sérialisée en JSON).
  investors      Json?
  sector         String?
  /// Résumé court de l'opération (~2 phrases).
  summary        String?              @db.Text
  /// Pays principal de l'opération (ISO 3166-1 alpha-2, ex : "FR").
  primaryCountry String               @db.VarChar(5)
  sourceUrl      String
  publishedAt    DateTime?
  status         NewsletterDealStatus @default(DRAFT)
  /// Identifiant du NewsletterFeedItem dont ce deal a été extrait.
  feedItemId     String?
  /// Modèle LLM utilisé pour l'extraction.
  extractedBy    String?
  /// Version du prompt utilisé.
  promptVersion  String?
  /// Score de confiance LLM (0–1).
  confidence     Float?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status, primaryCountry])
  @@index([publishedAt])
  @@index([feedItemId])
}


model Notification {
  id         String               @id @default(uuid())
  profileId  String               // Destinataire de la notification
  type       NotificationType
  category   NotificationCategory
  title      String
  message    String
  data       Json?                // Données contextuelles (postId, commentId, startupId, etc.)
  read       Boolean              @default(false)
  actorId    String?              // Profil qui a déclenché la notification (peut être null pour système)
  entityId   String?              // ID de l'entité concernée (post, comment, startup, etc.)
  entityType String?              // Type de l'entité (POST, COMMENT, STARTUP, etc.)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([profileId])
  @@index([profileId, read])
  @@index([profileId, category])
  @@index([createdAt])
}

enum NotificationType {
  // Engagement
  LIKE
  COMMENT
  COMMENT_REPLY
  MENTION
  SHARE
  FOLLOW
  PROFILE_VIEW
  DATAROOM_ENGAGEMENT

  // Invitations
  STARTUP_INVITATION
  INVESTOR_INVITATION
  DATAROOM_INVITATION
  CONNECTION_REQUEST
  REFERRAL_ACCEPTED

  // Système
  SYSTEM_ANNOUNCEMENT
  DATAROOM_UPDATE
  DOCUMENT_UPLOADED
  STARTUP_UPDATE
  ACHIEVEMENT_UNLOCKED
}

enum NotificationCategory {
  ENGAGEMENT
  INVITATIONS
  SYSTEM
}


