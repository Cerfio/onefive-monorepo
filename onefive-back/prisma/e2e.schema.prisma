  STRATEGIC_ADVISOR
  STUDENT_ENTREPRENEUR
  SERVICE_PROVIDER
  MEDIA
  INCUBATOR_ACCELERATOR
  RECRUITER_HR
  OTHER
}

enum WaitlistStatus {
  WAITING
  ACTIVE
  IGNORED
}



// Referral/Parrainage system
model Referral {
  id              String         @id @default(uuid())
  referrerId      String         // Le parrain (celui qui invite)
  invitedEmail    String         // Email de la personne invitée
  invitedProfileId String?       @unique // Lié après création du profil
  status          ReferralStatus @default(PENDING)
  code            String         @unique @default(uuid()) // Code unique pour le tracking
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  acceptedAt      DateTime?      // Date d'acceptation (inscription complétée)
  expiresAt       DateTime?      // Date d'expiration de l'invitation

  referrer        Profile        @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  invitedProfile  Profile?       @relation("ReferralReceived", fields: [invitedProfileId], references: [id])

  @@unique([referrerId, invitedEmail])
  @@index([referrerId])
  @@index([invitedEmail])
  @@index([status])
  @@index([code])
  @@index([referrerId, status])
}

// Stats de parrainage pour chaque profil (no counters - computed dynamically)
model ReferralStats {
  id              String   @id @default(uuid())
  profileId       String   @unique
  currentTier     String   @default("starter")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum ReferralStatus {
  PENDING    // Invitation envoyée, en attente
  ACCEPTED   // L'invité a créé son compte
  EXPIRED    // L'invitation a expiré
  CANCELLED  // L'invitation a été annulée
}


model Report {
  id           String       @id @default(uuid())
  reporterId   String
  resourceType ReportResourceType
  resourceId   String
  reason       ReportReason
  message      String?      @db.VarChar(500)
  status       ReportStatus @default(PENDING)
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reporter     Profile      @relation("ReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([createdAt])
}

model Feedback {
  id          String         @id @default(uuid())
  reporterId  String
  type        FeedbackType
  message     String         @db.VarChar(500)
  url         String?        @db.VarChar(500)
  browserInfo String?        @db.VarChar(500)
  screenshotId String?
  status      ReportStatus   @default(PENDING)
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  reporter    Profile        @relation("FeedbackSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)
  screenshot  File?          @relation("FeedbackScreenshot", fields: [screenshotId], references: [id])

  @@index([reporterId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum ReportResourceType {
  PROFILE
  POST
  POST_COMMENT
  POST_COMMENT_REPLY
  DISCUSSION
  DISCUSSION_ANSWER
  DISCUSSION_ANSWER_REPLY
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  MISINFORMATION
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum FeedbackType {
  BUG
  SUGGESTION
  COMMENT
  FUNCTIONAL
}


model Session {
  id                String   @id @default(uuid())
  sessionId         String   @unique @default(uuid())
  userId            String
  token             String   @unique
  fingerprint       String   @default("")
  deviceFingerprint String   @default("") // Stable fingerprint based on userAgent (for new device detection)
  isOtpOnlySession  Boolean  @default(false)
  isRevoked         Boolean  @default(false)
  lastUsage         DateTime @default(now())
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deviceInfo        String   @default("")
  ipAddress         String   @default("")
  location          String   @default("")
  userAgent         String   @default("")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, deviceFingerprint]) // Index for new device detection
  @@index([userId, isRevoked])
}


model Spot {
  id             String              @id @default(uuid())
  url            String
  spot           SpotType
  name           String
  highlight      String?
  address        String?
  image          String?
  description    String?
  location       Json?
  provider       ProviderType
  raw            Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  accelerator    SpotAccelerator?
  contest        SpotContest?
  coworkingSpace SpotCoworkingSpace?
  event          SpotEvent?
  incubator      SpotIncubator?

  @@map("spots")
}

model SpotAccelerator {
  id               String                 @id @default(uuid())
  spotId           String                 @unique
  expertiseDomains ExpertiseDomain[]
  hiringPeriod     Periodicity?
  date             DateTime?
  fundingModel     FundingModel?
  equityPercentage Float?
  investmentAmount Float?
  stage            StartupStage?
  capacity         Int?
  programDuration  Int?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  spot             Spot                   @relation(fields: [spotId], references: [id], onDelete: Cascade)
  prices           SpotAcceleratorPrice[]
}

model SpotContest {
  id               String             @id @default(uuid())
  spotId           String             @unique
  beginDate        DateTime
  endDate          DateTime
  expertiseDomains ExpertiseDomain[]
  prizeType        PrizeType?
  prizeAmount      Float?
  eligibility      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  spot             Spot               @relation(fields: [spotId], references: [id], onDelete: Cascade)
  prices           SpotContestPrice[]
}

model SpotEvent {
  id               String            @id @default(uuid())
  spotId           String            @unique
  beginDate        DateTime
  endDate          DateTime
  uniqueId         String            @unique
  expertiseDomains ExpertiseDomain[]
  days             Day[]
  format           EventFormat?
  attendees        Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  spot             Spot              @relation(fields: [spotId], references: [id], onDelete: Cascade)
  prices           SpotEventPrice[]
}

model SpotIncubator {
  id               String               @id @default(uuid())
  spotId           String               @unique
  expertiseDomains ExpertiseDomain[]
  hiringPeriod     Periodicity?
  dates            String[]
  fundingModel     FundingModel?
  equityPercentage Float?
  investmentAmount Float?
  stage            StartupStage?
  capacity         Int?
  programDuration  Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  spot             Spot                 @relation(fields: [spotId], references: [id], onDelete: Cascade)
  prices           SpotIncubatorPrice[]
}

model SpotCoworkingSpace {
  id           String                    @id @default(uuid())
  spotId       String                    @unique
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  spot         Spot                      @relation(fields: [spotId], references: [id], onDelete: Cascade)
  prices       SpotCoworkingSpacePrice[]
  openingHours SpotOpeningHours?
}

model SpotAcceleratorPrice {
  id            String          @id @default(uuid())
  acceleratorId String
  periodicity   Periodicity
  planId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accelerator   SpotAccelerator @relation(fields: [acceleratorId], references: [id], onDelete: Cascade)
  plan          SpotPricePlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SpotContestPrice {
  id        String        @id @default(uuid())
  contestId String
  planId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contest   SpotContest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  plan      SpotPricePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SpotEventPrice {
  id        String        @id @default(uuid())
  eventId   String
  planId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  event     SpotEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  plan      SpotPricePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SpotIncubatorPrice {
  id          String        @id @default(uuid())
  incubatorId String
  periodicity Periodicity
  planId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  incubator   SpotIncubator @relation(fields: [incubatorId], references: [id], onDelete: Cascade)
  plan        SpotPricePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SpotCoworkingSpacePrice {
  id               String             @id @default(uuid())
  coworkingSpaceId String
  periodicity      Periodicity
  planId           String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  coworkingSpace   SpotCoworkingSpace @relation(fields: [coworkingSpaceId], references: [id], onDelete: Cascade)
  plan             SpotPricePlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SpotPricePlan {
  id                   String                    @id @default(uuid())
  name                 String
  price                Float
  currency             String
  fee                  Float
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  acceleratorPrices    SpotAcceleratorPrice[]
  contestPrices        SpotContestPrice[]
  coworkingSpacePrices SpotCoworkingSpacePrice[]
  eventPrices          SpotEventPrice[]
  incubatorPrices      SpotIncubatorPrice[]
}

model SpotOpeningHours {
  id               String             @id @default(uuid())
