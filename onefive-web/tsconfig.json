{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/context/*": ["./src/context/*"],
      "@/logos/*": ["./assets/logos/*"],
      "@/flags/*": ["./assets/flags/*"],
      "@/icons/*": ["./assets/icons/*"],
      "@/images/*": ["./assets/images/*"],
      "@/lotties/*": ["./assets/lotties/*"],
      "@/ui/*": ["./src/ui/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/config/*": ["./config/*"],
      "@/types/*": ["./src/shared/types/*"],
      "@/enums/*": ["./src/shared/enums/*"],
      "@/constants/*": ["./src/shared/constants/*"],
      "@/base/*": ["./src/components/base/*"],
      "@/assets/*": ["./assets/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "components/*"],
  "exclude": ["node_modules", "**/node_modules/*", "**/staticresources/*", "src/examples"]
}
