# ==============================================
# onefive-front — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in values.

# --- Dev mode (enables dev-only UI, e.g. waitlist self-activate button) ---
NEXT_PUBLIC_DEV=false

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:50050

# --- Public URL (for sharing links, social media, SEO) ---
NEXT_PUBLIC_URL_PUBLIC=http://localhost:3002

# --- Analytics: PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=

# --- WebSocket ---
NEXT_PUBLIC_WS_URL=http://localhost:50050

# --- OAuth: LinkedIn ---
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=

# --- OAuth: Google ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- OAuth redirect URIs ---
NEXT_PUBLIC_AUTH_REDIRECT_URI=http://localhost:3002/auth/oauth2/callback
NEXT_PUBLIC_AUTH_REDIRECT_URI_ONBOARDING=http://localhost:3002/auth/oauth2/callback/onboarding

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
