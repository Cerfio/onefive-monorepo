# landing-page — environment variables
#
# Copy to .env.local and fill in. Every variable below is read by the code;
# nothing here is aspirational. If you add a process.env read, add it here too.
#
# Not listed, because Vercel provides them: VERCEL and VERCEL_ENV (read by
# scripts/migrate-if-production.mjs to decide whether a build may migrate) and
# NODE_ENV. They come from "Automatically expose System Environment Variables",
# which must stay enabled or the production build fails by design.

# --- Database (Payload) -----------------------------------------------------
# Postgres connection string. Preview deployments currently share this with
# production, which is why only the production build runs migrations.
DATABASE_URI=postgres://user:password@host/db

# Signs Payload's auth tokens. Any long random string; changing it logs
# everyone out of /studio-9k4x2m.
PAYLOAD_SECRET=

# --- Media storage (Cloudflare R2) ------------------------------------------
# Two buckets, on purpose. R2_BUCKET_NAME holds the media and media-articles
# collections and is served publicly by NEXT_PUBLIC_CDN_URL, which bypasses
# Payload's access control. R2_RESUMES_BUCKET_NAME holds applicant CVs and must
# never have a custom domain — the resumes collection's logged-in-only read rule
# is all that protects them. Do not merge the two.
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=onefive-assets
R2_RESUMES_BUCKET_NAME=onefive-landing-page-media
# Must be scoped to both buckets above, Object Read & Write.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- onefive-web gateway ----------------------------------------------------
# Origin of the app deployment, no trailing slash. The middleware proxies
# /profile, /post, /startup, /spotlight/<id>, /discussion, /signin and /signup
# there. Unset, those paths 404 instead — the app's entire public SEO surface.
# The middleware logs when it is missing, but it should simply always be set.
ONEFIVE_WEB_ORIGIN=https://onefive-web.vercel.app

# --- Public (exposed to the browser) ----------------------------------------
# Base URL for media served from R2. Note: /[locale]/about is prerendered and
# reads the team's images through this, so an unset value fails the build.
NEXT_PUBLIC_CDN_URL=https://assets.onefive.app

# PostHog project key. Analytics are skipped when unset — the app still runs.
NEXT_PUBLIC_POSTHOG_KEY=
