{
  "name": "onefive-landing-page-bo",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3005",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 3005",
    "vercel-build": "cross-env NODE_OPTIONS=--no-deprecation next build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.775.0",
    "@payloadcms/db-postgres": "3.77.0",
    "@payloadcms/next": "3.77.0",
    "@payloadcms/payload-cloud": "3.77.0",
    "@payloadcms/plugin-cloud-storage": "3.77.0",
    "@payloadcms/richtext-lexical": "3.77.0",
    "@payloadcms/storage-s3": "3.77.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "next": "15.4.11",
    "payload": "3.77.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.32.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "prettier": "^3.4.2",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "24.x"
  }
}
