# Workspace root — pnpm lit ce fichier pour toutes les apps.
# (Les .npmrc dans les sous-dossiers ne s’appliquent pas au hoist à la racine.)

# Évite plusieurs copies de @types/react : sinon TS voit deux `ReactNode` incompatibles (web / backoffice + react-aria).
public-hoist-pattern[]=*@types/react*
public-hoist-pattern[]=*@types/react-dom*

@untitledui-pro:registry=https://pkg.untitledui.com
//pkg.untitledui.com/:_authToken=${UNTITLEDUI_PRO_TOKEN}
