# URL du backend NestJS (sans slash final)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# URL de l'app onefive (pour les liens "Voir sur l'app")
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3002

# Storage S3/R2 (LocalStack en dev, Cloudflare R2 en prod)
NEXT_PUBLIC_STORAGE_BASE_URL=http://localhost:4566
NEXT_PUBLIC_STORAGE_BUCKET=onefive-storage

# Sentry error tracking (optional — leave empty to disable)
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (expected — Sentry DSNs are public by design).
# SENTRY_DSN is used by server-side / edge runtime.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# IMPORTANT: Côté backend (onefive-back/.env), ajouter cette URL dans FRONTEND_URL :
# FRONTEND_URL=http://localhost:3001,http://localhost:3003
# (virgule-séparée, 3001 = onefive-front, 3003 = onefive-backoffice)
